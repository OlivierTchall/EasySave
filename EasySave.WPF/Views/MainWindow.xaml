<Window x:Class="EasySave.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:EasySave.WPF.Localization"
        Title="{Binding L[app.title]}" Height="650" Width="950"
        MinHeight="450" MinWidth="650"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <loc:BindingProxy x:Key="Proxy" Data="{Binding}"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4A9EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E7FDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A5FAA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3A3A5C"/>
                                <Setter Property="Foreground" Value="#666688"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E05252"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C03A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#2D2D4A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#16162A"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2D2D4A"/>
            <Setter Property="RowBackground" Value="#1E1E2E"/>
            <Setter Property="AlternatingRowBackground" Value="#16162A"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D2D4A"/>
            <Setter Property="Foreground" Value="#4A9EFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#3D3D6A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3A5A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252540"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#12122A">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" Background="#4A9EFF" CornerRadius="8" Margin="0,0,12,0">
                        <TextBlock Text="ES" FontWeight="Bold" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="EasySave" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="v2.0 — ProSoft" FontSize="11" Foreground="#6666AA"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="#1A1A30" BorderBrush="#2D2D4A" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <Button Content="{Binding L[btn.run.all]}" Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartAllCommand}"/>
                <Button Content="{Binding L[btn.add]}" Style="{StaticResource SecondaryButton}"
                        Command="{Binding AddJobCommand}"/>
                <Button Content="{Binding L[btn.edit]}" Style="{StaticResource SecondaryButton}"
                        Command="{Binding EditJobCommand}"/>
                <Button Content="{Binding L[btn.delete]}" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteJobCommand}"/>
                <Separator Background="#2D2D4A" Width="1" Height="28" Margin="8,0"/>
                <Button Content="{Binding L[btn.settings]}" Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenSettingsCommand}"/>
            </StackPanel>
        </Border>

        <!-- DATAGRID -->
        <DataGrid Grid.Row="2" Margin="16"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding Data.L[col.name], Source={StaticResource Proxy}}"
                                    Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="{Binding Data.L[col.source], Source={StaticResource Proxy}}"
                                    Binding="{Binding SourcePath}" Width="*"/>
                <DataGridTextColumn Header="{Binding Data.L[col.target], Source={StaticResource Proxy}}"
                                    Binding="{Binding TargetPath}" Width="*"/>
                <DataGridTextColumn Header="{Binding Data.L[col.status], Source={StaticResource Proxy}}"
                                    Binding="{Binding Status}" Width="110"/>
                <DataGridTemplateColumn Header="Progress" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="8,0">
                                <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                             Height="8" Background="#2D2D4A" Foreground="#4A9EFF"/>
                                <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                                           HorizontalAlignment="Center" FontSize="10"
                                           Foreground="#AAAACC" Margin="0,10,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#12122A" BorderBrush="#2D2D4A" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#6666AA" FontSize="12" VerticalAlignment="Center"/>
                <ProgressBar Width="100" Height="4" HorizontalAlignment="Right"
                             IsIndeterminate="True" Foreground="#4A9EFF" Background="#2D2D4A"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
